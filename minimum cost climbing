     int solve(int i,int cost[], int dp[]){
         if(i>=cost.length){
             return 0;
         }
         if(dp[i]!=-1) return dp[i];
         int take1=cost[i]+solve(i+1,cost,dp);
         int take2=cost[i]+solve(i+2,cost,dp);
         return dp[i] = Math.min(take1,take2);
     }

//bottom up
    int n=cost.length;
