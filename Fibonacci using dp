
given int n and to find fib of n

///main logic is fib(2)=fib(0)+fib(1)
=>fib(n)=fib(n-1)+fib(n-2).

//top down approach

int[] dp=new int[n+1];
return solve(dp,n)
public int solve(int[] dp,int n){
if(n<=1){
return n;
}
if(dp[n]!=-2){
return dp[n];
}
return solve(n-1,dp)+solve(n-2,dp);
}


//bottom up approach

int[] dp=new int[n+1]
if(n<=1){
return n;
}
dp[0]=0;
dp[1]=1;
for(int i=2;i<=n;i++){
dp[i]=dp[i-1]+dp[i-2];

}
return dp[n];
}
